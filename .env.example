# ==================== 数据库配置 ====================
# 开发环境使用 SQLite
DATABASE_URL="file:./dev.db"
DIRECT_DATABASE_URL="file:./dev.db"

# 生产环境使用 PostgreSQL（Vercel 部署时自动配置）
# DATABASE_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true&connect_timeout=15"
# DIRECT_DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ==================== 邮件服务配置 ====================
# 选择一种邮件服务提供商

# QQ 邮箱配置（推荐国内使用）
MAIL_PROVIDER=qq
QQ_EMAIL=your_qq_number@qq.com
QQ_SMTP_AUTH=your_smtp_auth_code

# Gmail 配置（需要应用专用密码）
# MAIL_PROVIDER=gmail
# GMAIL_EMAIL=your_email@gmail.com
# GMAIL_APP_PASSWORD=your_app_password

# 自定义 SMTP 配置
# MAIL_PROVIDER=custom
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SSL=false
# SMTP_USER=your_username
# SMTP_PASS=your_password

# ==================== 应用安全配置 ====================
# Session 密钥（生产环境必须更改）
SECRET_KEY=your-secret-key-change-this-in-production-min-32-characters

# JWT 密钥（用于 API 认证）
JWT_SECRET=your-jwt-secret-change-this-in-production-min-32-characters

# 密码加密盐值
BCRYPT_SALT_ROUNDS=10

# ==================== 会话配置 ====================
# 会话过期时间（小时）
SESSION_EXPIRY_HOURS=168

# 多设备登录限制（0 表示不限制）
MAX_LOGIN_DEVICES=3

# ==================== 邮箱验证配置 ====================
# 邮箱验证链接过期时间（小时）
EMAIL_VERIFY_EXPIRY_HOURS=24

# 密码重置链接过期时间（小时）
PASSWORD_RESET_EXPIRY_HOURS=1

# 发件人信息
EMAIL_FROM_NAME=邮件营销系统
EMAIL_FROM_ADDRESS=noreply@example.com

# ==================== 应用配置 ====================
# 运行环境
NODE_ENV=development

# 应用 URL（生产环境需配置）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API 前缀
NEXT_PUBLIC_API_PREFIX=/api

# ==================== 文件上传配置 ====================
# 最大文件大小（MB）
MAX_FILE_SIZE_MB=10

# 允许的文件类型
ALLOWED_FILE_TYPES=.csv,.xlsx,.xls

# ==================== 发送限制配置 ====================
# 单用户每日发送上限
USER_DAILY_EMAIL_LIMIT=500

# 单用户每月发送上限
USER_MONTHLY_EMAIL_LIMIT=10000

# 默认邮件发送间隔（秒）
DEFAULT_EMAIL_INTERVAL=5

# ==================== 监控配置 ====================
# Sentry DSN（可选，用于错误监控）
# SENTRY_DSN=https://your-sentry-dsn

# 日志级别
LOG_LEVEL=info

# ==================== 第三方服务配置 ====================
# Redis 配置（可选，用于缓存和队列）
# REDIS_URL=redis://localhost:6379

# CDN 配置（可选）
# CDN_URL=https://your-cdn-url.com
