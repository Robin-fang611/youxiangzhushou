# ===========================================
# 邮件营销系统 - 环境变量配置示例
# ===========================================
# 使用说明:
# 1. 复制此文件为 .env (本地开发) 或在 Vercel 中配置
# 2. 根据选择的邮件服务商配置相应变量
# 3. 不要将此文件提交到 Git (已添加到 .gitignore)
# ===========================================

# ===========================================
# 1. 邮件服务提供商选择 (必填)
# ===========================================
# 可选值：nodemailer, resend
# nodemailer: 使用 SMTP 协议 (QQ 邮箱、Gmail 等)
# resend: 使用 Resend API (推荐用于生产环境)
EMAIL_PROVIDER=nodemailer

# ===========================================
# 2. Nodemailer SMTP 配置 (如果使用 nodemailer)
# ===========================================
# 适用于 QQ 邮箱、Gmail、企业邮箱等

# SMTP 服务器地址
SMTP_HOST=smtp.qq.com

# SMTP 端口 (465=SSL, 587=TLS)
SMTP_PORT=465

# 是否使用 SSL (端口 465 时必须为 true)
SMTP_SSL=true

# SMTP 用户名 (通常是邮箱地址)
SMTP_USER=your_email@qq.com

# SMTP 密码/授权码
# QQ 邮箱：使用 SMTP 授权码 (不是登录密码)
# Gmail: 使用应用专用密码
SMTP_PASS=your_smtp_auth_code

# 发件人邮箱地址 (默认使用 SMTP_USER)
SMTP_FROM=your_email@qq.com

# 发件人显示名称
FROM_NAME=Business Bot

# ===========================================
# 3. Resend API 配置 (如果使用 resend)
# ===========================================
# 适用于生产环境，更好的送达率和监控

# Resend API Key (在 https://resend.com 获取)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Resend 发件人邮箱 (需要在 Resend 后台验证)
RESEND_FROM_EMAIL=onboarding@resend.dev

# Resend 发件人名称
RESEND_FROM_NAME=Business Bot

# ===========================================
# 4. 旧版 QQ 邮箱配置 (兼容模式)
# ===========================================
# 如果使用 EMAIL_PROVIDER=qq (不推荐，建议用 nodemailer)

QQ_EMAIL=your_qq@qq.com
QQ_SMTP_AUTH=your_auth_code

# ===========================================
# 5. 旧版 Gmail 配置 (兼容模式)
# ===========================================
# 如果使用 EMAIL_PROVIDER=gmail (不推荐，建议用 nodemailer)

GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# ===========================================
# 6. 数据库配置 (Vercel 生产环境)
# ===========================================

# PostgreSQL 连接字符串 (带连接池)
DATABASE_URL=postgresql://user:password@host:5432/dbname?pgbouncer=true

# PostgreSQL 直连字符串 (用于迁移)
DIRECT_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===========================================
# 7. 安全配置
# ===========================================

# Session 密钥 (至少 32 个字符)
SECRET_KEY=your-super-secret-key-min-32-characters-long

# JWT 密钥 (至少 32 个字符)
JWT_SECRET=your-jwt-secret-key-min-32-characters

# ===========================================
# 8. 应用配置
# ===========================================

# 运行环境
NODE_ENV=development

# 应用 URL (生产环境)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# 配置示例
# ===========================================

# 示例 1: 使用 QQ 邮箱 (nodemailer)
# EMAIL_PROVIDER=nodemailer
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SSL=true
# SMTP_USER=123456@qq.com
# SMTP_PASS=your_qq_auth_code
# SMTP_FROM=123456@qq.com
# FROM_NAME=Business Bot

# 示例 2: 使用 Gmail (nodemailer)
# EMAIL_PROVIDER=nodemailer
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SSL=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=your_email@gmail.com
# FROM_NAME=Business Bot

# 示例 3: 使用 Resend (推荐生产环境)
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=contact@yourdomain.com
# RESEND_FROM_NAME=Your Company

# ===========================================
# 获取 SMTP 授权码指南
# ===========================================

# QQ 邮箱:
# 1. 登录 https://mail.qq.com
# 2. 设置 > 账户 > 开启 POP3/SMTP 服务
# 3. 获取 16 位授权码

# Gmail:
# 1. 开启两步验证
# 2. 创建应用专用密码
# 3. 使用应用密码作为 SMTP_PASS

# 163 邮箱:
# 1. 登录 https://mail.163.com
# 2. 设置 > POP3/SMTP/IMAP
# 3. 开启 SMTP 服务并获取授权码

# ===========================================
# Vercel 部署配置清单
# ===========================================
# 在 Vercel Dashboard > Settings > Environment Variables 添加:
# 
# ✅ EMAIL_PROVIDER=nodemailer
# ✅ SMTP_HOST=smtp.qq.com
# ✅ SMTP_PORT=465
# ✅ SMTP_SSL=true
# ✅ SMTP_USER=your_email@qq.com
# ✅ SMTP_PASS=your_auth_code
# ✅ SMTP_FROM=your_email@qq.com
# ✅ DATABASE_URL=postgresql://...
# ✅ DIRECT_DATABASE_URL=postgresql://...
# ✅ SECRET_KEY=your-secret-key
# ✅ NODE_ENV=production
# ===========================================
